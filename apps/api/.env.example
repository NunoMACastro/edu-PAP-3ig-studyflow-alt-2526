# StudyFlow API environment
#
# Copiar este ficheiro para `apps/api/.env` e preencher apenas os valores
# necessários.
# Do not commit `.env` with real secrets.

NODE_ENV=development
STUDYFLOW_DEPLOYMENT_SCOPE=local-pap
HOST=127.0.0.1
PORT=3000
WEB_ORIGIN=http://127.0.0.1:5173
STUDYFLOW_TRUST_PROXY=false

# MongoDB local iniciado por `apps/compose.yaml`.
MONGODB_URI=mongodb://127.0.0.1:27017/studyflow?replicaSet=studyflow-rs
# Alternativa remota com MongoDB Atlas (nunca guardar credenciais reais aqui).
# MONGODB_URI=mongodb+srv://<UTILIZADOR>:<PASSWORD>@<CLUSTER>.mongodb.net/studyflow?retryWrites=true&w=majority&appName=StudyFlow
REDIS_URL=redis://127.0.0.1:6379/1
# Por omissão, os materiais ficam em ~/.studyflow/studyflow-materials.
# Para substituir esse diretório, usar um caminho absoluto fora do checkout e
# cujo último segmento comece por "studyflow-". O ficheiro .env não expande ~.
# Windows: MATERIALS_STORAGE_DIR=C:/Users/UTILIZADOR/AppData/Local/StudyFlow/studyflow-materials
# macOS: MATERIALS_STORAGE_DIR="/Users/UTILIZADOR/Library/Application Support/StudyFlow/studyflow-materials"
MATERIALS_STORAGE_USER_QUOTA_BYTES=262144000
MATERIALS_STORAGE_GLOBAL_QUOTA_BYTES=5368709120
MATERIALS_STORAGE_STAGING_RETENTION_MS=3600000
MATERIALS_STORAGE_ORPHAN_RETENTION_MS=86400000
MATERIALS_STORAGE_RECONCILE_INTERVAL_MS=60000
QUIZ_JOB_LEASE_MS=30000
QUIZ_JOB_POLL_MS=1000
MATERIAL_INDEX_JOB_LEASE_MS=30000
MATERIAL_INDEX_JOB_POLL_MS=1000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=8000

# Dangerous local actions are fail-closed. Enable only for the intended command.
STUDYFLOW_ALLOW_DEV_SEED=false
STUDYFLOW_ALLOW_ADMIN_BOOTSTRAP=false
STUDYFLOW_ADMIN_EMAIL=
STUDYFLOW_ADMIN_PASSWORD=
STUDYFLOW_ALLOW_DATA_RESET=false
STUDYFLOW_RESET_CONFIRMATION=
# Legacy MF8 generators are historical only and write below docs/evidence/MF8/historico/gerado/.
STUDYFLOW_ALLOW_LEGACY_MF8_EVIDENCE=false

# Public deployment host used only by `npm run verify:tls`.
# Use host[:port] without protocol, path, query or fragment.
API_PUBLIC_HOST=
# Optional when plain HTTP is exposed on a non-standard port.
API_PUBLIC_HTTP_PORT=80
STUDYFLOW_TLS_TIMEOUT_MS=7000
# Set to true only for isolated staging/self-signed certificate evidence.
STUDYFLOW_TLS_ALLOW_SELF_SIGNED=false

# Required by `npm run backup:daily`; use a durable dedicated folder outside the checkout.
# Replace UTILIZADOR literally. /tmp is reserved for disposable restore/E2E drills.
STUDYFLOW_BACKUP_DIR="/Users/UTILIZADOR/Library/Application Support/StudyFlow/studyflow-backups"
STUDYFLOW_BACKUP_RETENTION_DAYS=7
# 32 random bytes encoded as base64 or 64 hexadecimal characters. Never store the value here.
STUDYFLOW_BACKUP_KEY=
STUDYFLOW_BACKUP_OFFLINE_CONFIRMED=false
STUDYFLOW_RESTORE_DIR=
STUDYFLOW_ALLOW_RESTORE=false
STUDYFLOW_RESTORE_CONFIRMATION=
STUDYFLOW_RESTORE_STORAGE_CONFIRMATION=

# Snapshot autenticado opcional da implementação, fora de `apps/api`.
STUDYFLOW_RELEASE_SNAPSHOT_ROOT=/tmp/studyflow-release-snapshots
# Chave independente de 32 bytes; nunca reutilizar STUDYFLOW_BACKUP_KEY.
STUDYFLOW_RELEASE_SNAPSHOT_KEY=
STUDYFLOW_ALLOW_RELEASE_ROLLBACK=false
STUDYFLOW_RELEASE_ROLLBACK_SNAPSHOT=
STUDYFLOW_RELEASE_ROLLBACK_CONFIRMATION=

# Gates manuais ligados ao SHA-256 devolvido por `npm run manifest:hash`.
STUDYFLOW_RELEASE_RESTORE_DRILL_SHA256=
STUDYFLOW_RELEASE_CRASH_RECOVERY_SHA256=
STUDYFLOW_RELEASE_CROSS_BROWSER_SHA256=

# Optional runtime identity for horizontal-scaling evidence.
STUDYFLOW_INSTANCE_ID=

# Optional E2E/runtime smoke configuration.
STUDYFLOW_E2E_API_PORT=
STUDYFLOW_E2E_WEB_PORT=
STUDYFLOW_E2E_START_SERVERS=true
STUDYFLOW_E2E_REUSE_SERVERS=false
STUDYFLOW_E2E_MONGODB_URI=
STUDYFLOW_E2E_REDIS_URL=
STUDYFLOW_E2E_STUDENT_EMAIL=aluno.dev@studyflow.local
STUDYFLOW_E2E_STUDENT_PASSWORD=aluno-dev-12345
STUDYFLOW_E2E_TEACHER_EMAIL=professor.dev@studyflow.local
STUDYFLOW_E2E_TEACHER_PASSWORD=professor-dev-12345

STUDYFLOW_BASE_URL=http://127.0.0.1:3000
STUDYFLOW_SMOKE_PATH=/api/auth/me
STUDYFLOW_SMOKE_USERS=200
STUDYFLOW_SMOKE_EXPECTED_STATUS=200
STUDYFLOW_SMOKE_SCHOOL_CONTEXT=escola-teste-isolada
STUDYFLOW_SMOKE_COOKIE=
STUDYFLOW_SMOKE_EMAIL=
STUDYFLOW_SMOKE_PASSWORD=

STUDYFLOW_RUNTIME_INSTANCE_URLS=
STUDYFLOW_RUNTIME_PORT_A=3301
STUDYFLOW_RUNTIME_PORT_B=3302
STUDYFLOW_RUNTIME_TIMEOUT_MS=30000
STUDYFLOW_RUNTIME_REQUESTS=4

# Instância local separada com uma dependência desligada; deve devolver 503.
STUDYFLOW_NEGATIVE_READINESS_URL=
STUDYFLOW_NEGATIVE_READINESS_TIMEOUT_MS=5000
