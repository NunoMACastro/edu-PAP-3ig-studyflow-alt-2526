# StudyFlow API environment
#
# Copy this file to `.env` inside `real_dev/api/` and fill the real values.
# Do not commit `.env` with real secrets.

NODE_ENV=development
PORT=3000
WEB_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/studyflow
REDIS_URL=redis://127.0.0.1:6379
MATERIALS_STORAGE_DIR=storage/materials

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=8000

# Public deployment host used only by `npm run verify:tls`.
# Use host[:port] without protocol, path, query or fragment.
API_PUBLIC_HOST=
# Optional when plain HTTP is exposed on a non-standard port.
API_PUBLIC_HTTP_PORT=80
STUDYFLOW_TLS_TIMEOUT_MS=7000
# Set to true only for isolated staging/self-signed certificate evidence.
STUDYFLOW_TLS_ALLOW_SELF_SIGNED=false

# Required by `npm run backup:daily`; use a dedicated folder outside the checkout.
# Replace this with durable storage in production.
STUDYFLOW_BACKUP_DIR=/tmp/studyflow-backups
STUDYFLOW_BACKUP_RETENTION_DAYS=7

# Optional runtime identity for horizontal-scaling evidence.
STUDYFLOW_INSTANCE_ID=

# Optional E2E/runtime smoke configuration.
STUDYFLOW_E2E_API_PORT=3000
STUDYFLOW_E2E_WEB_PORT=4175
STUDYFLOW_E2E_START_SERVERS=true
STUDYFLOW_E2E_IN_MEMORY_REDIS=false
STUDYFLOW_E2E_FAKE_AI=false
STUDYFLOW_E2E_STUDENT_EMAIL=aluno.dev@studyflow.local
STUDYFLOW_E2E_STUDENT_PASSWORD=aluno-dev-12345
STUDYFLOW_E2E_TEACHER_EMAIL=professor.dev@studyflow.local
STUDYFLOW_E2E_TEACHER_PASSWORD=professor-dev-12345

STUDYFLOW_BASE_URL=http://127.0.0.1:3000
STUDYFLOW_SMOKE_PATH=/api/auth/me
STUDYFLOW_SMOKE_USERS=200
STUDYFLOW_SMOKE_EXPECTED_STATUS=200
STUDYFLOW_SMOKE_SCHOOL_CONTEXT=escola-teste-isolada
STUDYFLOW_SMOKE_COOKIE=
STUDYFLOW_SMOKE_EMAIL=
STUDYFLOW_SMOKE_PASSWORD=

STUDYFLOW_RUNTIME_INSTANCE_URLS=
STUDYFLOW_RUNTIME_PORT_A=3301
STUDYFLOW_RUNTIME_PORT_B=3302
STUDYFLOW_RUNTIME_TIMEOUT_MS=30000
STUDYFLOW_RUNTIME_REQUESTS=4
