{
  "name": "@studyflow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": "24.11.1",
    "npm": "11.6.2"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:e2e": "nest build && node dist/scripts/start-e2e-api.js",
    "seed:dev-users": "nest build && node --env-file-if-exists=.env dist/scripts/seed-development-users.js",
    "admin:bootstrap:local": "nest build && node --env-file-if-exists=.env dist/scripts/bootstrap-local-admin.js",
    "data:reset:local": "nest build && node --env-file-if-exists=.env dist/scripts/reset-local-data.js",
    "smoke:200-users": "node --env-file-if-exists=.env src/scripts/smoke-200-users.mjs",
    "smoke:runtime-instances": "node --env-file-if-exists=.env src/scripts/smoke-runtime-instances.mjs",
    "smoke:runtime-instances:local": "npm run build && node --env-file-if-exists=.env src/scripts/smoke-runtime-instances.mjs --local",
    "verify:tls": "node --env-file-if-exists=.env src/scripts/verify-tls-evidence.mjs",
    "backup:daily": "nest build && node --env-file-if-exists=.env dist/scripts/backup-database.js",
    "backup:daily:dry-run": "nest build && node --env-file-if-exists=.env dist/scripts/backup-database.js --dry-run",
    "backup:restore": "nest build && node --env-file-if-exists=.env dist/scripts/restore-database.js",
    "release:snapshot": "nest build && node --env-file-if-exists=.env dist/scripts/release-snapshot.js",
    "release:rollback": "node --env-file-if-exists=.env dist/scripts/release-snapshot.js --rollback",
    "verify:local-release": "nest build && node --env-file-if-exists=.env dist/scripts/verify-local-release.js",
    "verify:local-release:plan": "nest build && node --env-file-if-exists=.env dist/scripts/verify-local-release.js --list",
    "mf8:test-inventory": "npm run mf8:test-inventory:historical",
    "mf8:test-inventory:historical": "nest build && node dist/scripts/mf8-test-inventory.js",
    "mf8:final-tests": "npm run mf8:final-tests:historical",
    "mf8:final-tests:historical": "nest build && node dist/scripts/run-mf8-final-tests.js",
    "mf8:error-register": "npm run mf8:error-register:historical",
    "mf8:error-register:historical": "nest build && node dist/scripts/mf8-error-register.js",
    "deploy:check": "npm run build && node --env-file-if-exists=.env dist/scripts/validate-deploy-readiness.js",
    "manifest:hash": "node src/scripts/generate-implementation-manifest.mjs",
    "technical-map:check": "nest build && node dist/scripts/export-technical-map.js --check",
    "technical-map:write": "nest build && node dist/scripts/export-technical-map.js --write",
    "function-inventory:check": "nest build && node dist/scripts/generate-function-inventory.js --check",
    "function-inventory:write": "nest build && node dist/scripts/generate-function-inventory.js --write",
    "docs:verify": "bash ../../scripts/verify-docs.sh",
    "secrets:scan": "node src/scripts/scan-sensitive-evidence.mjs",
    "smoke:readiness:negative": "node --env-file-if-exists=.env src/scripts/smoke-readiness-negative.mjs",
    "test": "jest --config ./jest.config.cjs --passWithNoTests",
    "test:unit": "npm test"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "bcrypt": "6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.4.1",
    "ipaddr.js": "2.4.0",
    "mammoth": "^1.12.0",
    "mongoose": "^8.0.0",
    "multer": "2.2.0",
    "openai": "^5.0.0",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.0"
  }
}
